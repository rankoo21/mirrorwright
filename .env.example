# PromptShield environment
# The app runs fully in mock mode with no configuration.

# "mock" (default) or "contract"
NEXT_PUBLIC_PROMPTSHIELD_MODE=mock

# Deployed PromptShieldContract address, used only in contract mode
NEXT_PUBLIC_PROMPTSHIELD_CONTRACT=

# studionet (default) | bradbury | localnet
NEXT_PUBLIC_PROMPTSHIELD_NETWORK=studionet
